# ============================================================
#                     BLASTER .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# --- Virtual Environment ---
venv/
env/
.env/
ENV/
.venv/

# --- Report Output Files ---
# These are generated by --output and should not be committed
*.html
*.json
*.txt
# Exception — keep README and requirements
!README.md
!requirements.txt

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Sensitive / Config ---
.env
config.json
secrets.json
*.key
*.pem

# --- Distribution / Build ---
dist/
build/
*.egg-info/
*.egg
.eggs/

# --- pytest / Testing ---
.pytest_cache/
.coverage
htmlcov/